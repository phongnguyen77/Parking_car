        private void Form1_FormClosing(object sender, FormClosingEventArgs e)
        {
            try
            {
                // Ensure controller cancels background tasks and stops devices
                _controller?.Stop();
            }
            catch { }

            try
            {
                _cams.StopAll();
                _serial.Close();
            }
            catch { }
        }

        private void Log(string msg)
        {
            if (InvokeRequired)
            {
                BeginInvoke(new Action(() => Log(msg)));
                return;
            }

            string line = $"[{DateTime.Now:HH:mm:ss}] {msg}";
            txtLog.AppendText(line + Environment.NewLine);
        }

        private void UpdateTotalCars(int total)
        {
            if (InvokeRequired)
            {
                BeginInvoke(new Action(() => UpdateTotalCars(total)));
                return;
            }

            txtTotalCars.Text = total.ToString();
        }

        // New: update totals for entries and exits
        private void UpdateTotalsEntryExit(int totalEntries, int totalExits)
        {
            // Ensure invoked on UI thread
            if (InvokeRequired)
            {
                BeginInvoke(new Action(() => UpdateTotalsEntryExit(totalEntries, totalExits)));
                return;
            }

            // create textboxes if they exist in designer
            try
            {
                txtTotalEntries.Text = totalEntries.ToString();
            }
            catch { }

            try
            {
                txtTotalExits.Text = totalExits.ToString();
            }
            catch { }
        }

        // Called by controller when OCR produces plate text for entry
        private void UpdatePlateEntry(string plate)
        {
            if (InvokeRequired)
            {
                BeginInvoke(new Action(() => UpdatePlateEntry(plate)));
                return;
            }

            try
            {
                var display = string.IsNullOrWhiteSpace(plate) ? "(Không đọc được)" : plate;
                txtPlateEntry.Text = display;
            }
            catch { }
            try { Log($"UpdatePlateEntry called -> '{plate}'"); } catch { }
        }

        // Called by controller when OCR produces plate text for exit
