        public Form1()
        {
            InitializeComponent();
            picEntry.SizeMode = PictureBoxSizeMode.Zoom;
            picExit.SizeMode = PictureBoxSizeMode.Zoom;

            picEntry.BackColor = Color.Black;
            picExit.BackColor = Color.Black;
            InitSystem();

